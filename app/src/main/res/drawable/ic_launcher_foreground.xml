<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Design: minimal upward-trending sparkline
        Safe zone: roughly 66×66dp centered → active area ~x:21-87, y:21-87
        Layout within that zone:
          Baseline  y=78, x: 24→84
          Sparkline from (24,78) trending up to (84,32)
          Green terminal dot at (84,32) r=7
          White inner ring at (84,32) r=3
    -->

    <!-- Subtle horizontal baseline -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeAlpha="0.2"
        android:strokeLineCap="round"
        android:pathData="M24,78 L84,78" />

    <!-- Small vertical tick marks at each data point on the baseline -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeAlpha="0.15"
        android:strokeLineCap="round"
        android:pathData="M39,78 L39,75 M54,78 L54,75 M69,78 L69,75" />

    <!-- Sparkline: realistic chart trending strongly upward -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M24,78 L39,67 L54,73 L69,53 L84,32" />

    <!-- Green filled circle at the peak (terminal data point) -->
    <path
        android:fillColor="#76C893"
        android:pathData="M77,32 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />

    <!-- White inner dot (gives a "live" pulsing feel) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M81,32 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />

</vector>
