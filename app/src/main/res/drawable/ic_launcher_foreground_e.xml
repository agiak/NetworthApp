<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left vertical stroke -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M30,78 L30,30" />

    <!-- Diagonal stroke (top-left to bottom-right) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M30,30 L78,78" />

    <!-- Right vertical stroke -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M78,78 L78,30" />

    <!-- Green accent dot at top-right corner of the N -->
    <path
        android:fillColor="#76C893"
        android:pathData="M72,30 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0" />

